<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <title>DuaAjan Admin Login</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>

  <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

  <style>
    body {
      margin: 0;
      min-height: 100vh;
      background: linear-gradient(135deg, #0f172a, #111827, #1e293b);
      display: flex;
      justify-content: center;
      align-items: center;
      font-family: Arial, sans-serif;
    }

    .login-card {
      width: 100%;
      max-width: 420px;
      background: #fff;
      border-radius: 24px;
      padding: 45px;
      box-shadow: 0 10px 40px rgba(0, 0, 0, 0.25);
    }

    .logo-box {
      width: 80px;
      height: 80px;
      background: #111827;
      color: #fff;
      border-radius: 20px;
      display: flex;
      justify-content: center;
      align-items: center;
      margin: auto;
      font-size: 32px;
      margin-bottom: 20px;
    }

    .title {
      text-align: center;
      font-weight: 700;
      font-size: 30px;
      color: #111827;
      margin-bottom: 8px;
    }

    .subtitle {
      text-align: center;
      color: #6b7280;
      margin-bottom: 35px;
      font-size: 14px;
    }

    .form-control {
      height: 55px;
      border-radius: 14px;
      border: 1px solid #d1d5db;
      padding-left: 15px;
      font-size: 15px;
    }

    .form-control:focus {
      box-shadow: none;
      border-color: #111827;
    }

    .btn-login {
      height: 55px;
      border: none;
      border-radius: 14px;
      background: #111827;
      color: #fff;
      font-weight: 600;
      transition: .3s;
    }

    .btn-login:hover {
      background: #000;
      transform: translateY(-2px);
    }

    .footer-text {
      text-align: center;
      margin-top: 25px;
      color: #9ca3af;
      font-size: 13px;
    }

    .alert {
      border-radius: 12px;
    }
  </style>

</head>

<body>

  <div id="app" class="login-card">

    <div class="logo-box">
      <i class="fa-solid fa-mosque"></i>
    </div>

    <h2 class="title">
      DuaAjan Admin
    </h2>

    <p class="subtitle">
      Secure Admin Login Panel
    </p>

    <!-- Mobile -->

    <div class="mb-4">

      <input
        type="text"
        v-model="mobile"
        class="form-control"
        placeholder="Enter Mobile Number"
        :disabled="showOtp"
      >

    </div>

    <!-- OTP -->

    <div
      class="mb-4"
      v-if="showOtp"
    >

      <input
        type="text"
        v-model="otp"
        class="form-control"
        placeholder="Enter OTP"
        maxlength="6"
      >

    </div>

    <!-- Message -->

    <div
      v-if="message"
      class="alert"
      :class="success ? 'alert-success' : 'alert-danger'"
    >

      {{ message }}

    </div>

    <!-- Send OTP -->

    <button
      v-if="!showOtp"
      class="btn btn-login w-100"
      @click="sendOtp"
      :disabled="loading"
    >

      <span v-if="loading">
        <span class="spinner-border spinner-border-sm me-2"></span>
        Sending...
      </span>

      <span v-else>
        Send OTP
      </span>

    </button>

    <!-- Verify OTP -->

    <button
      v-if="showOtp"
      class="btn btn-login w-100"
      @click="verifyOtp"
      :disabled="loading"
    >

      <span v-if="loading">
        <span class="spinner-border spinner-border-sm me-2"></span>
        Verifying...
      </span>

      <span v-else>
        Verify OTP
      </span>

    </button>

    <div class="footer-text">
      © 2026 DuaAjan. All rights reserved.
    </div>

  </div>

  <script>
    new Vue({
      el: "#app",

      data: {
        mobile: "",
        otp: "",
        showOtp: false,
        loading: false,
        message: "",
        success: false
      },

      methods: {

        async sendOtp() {

          if (!this.mobile) {

            this.success = false;
            this.message = "Please enter mobile number";

            return;
          }

          try {

            this.loading = true;
            this.message = "";

            const response = await axios.post("/admin/send-otp",{mobile: this.mobile});

            this.success = true;

            this.message = response.data.message || "OTP sent successfully";

            this.showOtp = true;

          } catch (error) {

            this.success = false;

            this.message = error.response?.data?.message || "Failed to send OTP";

          } finally {

            this.loading = false;
          }
        },

        async verifyOtp() {

          if (!this.otp) {

            this.success = false;
            this.message = "Please enter OTP";

            return;
          }

          try {

            this.loading = true;
            this.message = "";

            const response = await axios.post("/admin/verify-otp",{mobile: this.mobile, otp: this.otp});

            this.success = true;

            this.message = response.data.message || "Login successful";

            setTimeout(() => {
              window.location.href = "/admin/dashboard";
            }, 500);

          } catch (error) {

            this.success = false;

            this.message =
              error.response?.data?.message ||
              "Invalid OTP";

          } finally {

            this.loading = false;
          }
        }
      }
    });
  </script>

</body>

</html>