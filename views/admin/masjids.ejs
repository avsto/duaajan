
<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Masjids - DuaAjan Admin</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>

  <style>

    body{
      margin:0;
      background:#0f172a;
      color:#fff;
      font-family:Arial,sans-serif;
    }

    .topbar{
      background:#111827;
      padding:20px 30px;
      border-bottom:1px solid rgba(255,255,255,.08);
    }

    .brand{
      font-size:24px;
      font-weight:700;
    }

    .page-card{
      background:#111827;
      border-radius:24px;
      padding:25px;
      margin-top:30px;
      border:1px solid rgba(255,255,255,.05);
    }

    .search-box{
      background:#1e293b;
      border:none;
      color:#fff;
      height:50px;
      border-radius:14px;
    }

    .search-box:focus{
      background:#1e293b;
      color:#fff;
      box-shadow:none;
    }

    .table{
      color:#fff;
      margin-bottom:0;
    }

    .table thead{
      background:#1e293b;
    }

    .table th{
      border:none;
      color:#cbd5e1;
      padding:16px;
    }

    .table td{
      border-color:rgba(255,255,255,.05);
      padding:16px;
      vertical-align:middle;
    }

    .masjid-icon{
      width:50px;
      height:50px;
      border-radius:12px;
      background:#1e293b;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:22px;
      color:#60a5fa;
    }

    .badge-approved{
      background:#10b981;
    }

    .badge-pending{
      background:#f59e0b;
    }

    .badge-rejected{
      background:#ef4444;
    }

    .btn-action{
      border:none;
      border-radius:10px;
      padding:6px 12px;
      color:white;
      margin-right:5px;
      margin-bottom:5px;
    }

    .btn-view{
      background:#3b82f6;
    }

    .btn-approve{
      background:#10b981;
    }

    .btn-reject{
      background:#ef4444;
    }

    .btn-delete{
      background:#dc2626;
    }

    .pagination .page-link{
      background:#1e293b;
      border-color:#334155;
      color:#fff;
    }

    .pagination .active .page-link{
      background:#3b82f6;
      border-color:#3b82f6;
    }

  </style>

</head>

<body>

<div id="app">

  <div class="topbar">

    <div class="d-flex justify-content-between align-items-center">

      <div class="brand">
        <i class="fa-solid fa-mosque me-2"></i>
        Masjid Management
      </div>

      <a href="/admin/dashboard" class="btn btn-light">
        Dashboard
      </a>

    </div>

  </div>

  <div class="container py-4">

    <div class="page-card">

      <div class="d-flex justify-content-between align-items-center mb-4">

        <h3 class="mb-0">
          Total Masjids ({{ totalMasjids }})
        </h3>

        <input
          type="text"
          class="form-control search-box"
          style="max-width:320px"
          placeholder="Search Masjid..."
          v-model="search"
          @keyup.enter="searchMasjid"
        >

      </div>

      <div class="table-responsive">

        <table class="table">

          <thead>

            <tr>
              <th>Masjid</th>
              <th>Imam</th>
              <th>Mobile</th>
              <th>Status</th>
              <th>Address</th>
              <th width="260">Action</th>
            </tr>

          </thead>

          <tbody>

            <tr
              v-for="masjid in masjids"
              :key="masjid._id"
            >

              <td>

                <div class="d-flex align-items-center">

                  <div class="masjid-icon me-3">
                    <i class="fa-solid fa-mosque"></i>
                  </div>

                  <div>

                    <div class="fw-bold">
                      {{ masjid.masjidName }}
                    </div>

                    <small class="text-secondary">
                      {{ masjid.email }}
                    </small>

                  </div>

                </div>

              </td>

              <td>
                {{ masjid.imamName }}
              </td>

              <td>
                {{ masjid.mobile }}
              </td>

              <td>

                <span
                  class="badge"
                  :class="{
                    'badge-approved': masjid.status === 'approved',
                    'badge-pending': masjid.status === 'pending',
                    'badge-rejected': masjid.status === 'rejected'
                  }"
                >
                  {{ masjid.status }}
                </span>

              </td>

              <td>
                {{ masjid.address }}
              </td>

              <td>

                <button
                  class="btn-action btn-view"
                  @click="viewMasjid(masjid)"
                >
                  View
                </button>

                <button
                  v-if="masjid.status !== 'approved'"
                  class="btn-action btn-approve"
                  @click="updateStatus(masjid,'approved')"
                >
                  Approve
                </button>

                <button
                  v-if="masjid.status !== 'rejected'"
                  class="btn-action btn-reject"
                  @click="updateStatus(masjid,'rejected')"
                >
                  Reject
                </button>

                <button
                  class="btn-action btn-delete"
                  @click="deleteMasjid(masjid._id)"
                >
                  Delete
                </button>

              </td>

            </tr>

            <tr v-if="masjids.length === 0">

              <td colspan="6" class="text-center py-4">
                No Masjid Found
              </td>

            </tr>

          </tbody>

        </table>

      </div>

      <div class="d-flex justify-content-between align-items-center mt-4">

        <div>
          Page {{ page }} of {{ totalPages }}
        </div>

        <ul
          class="pagination mb-0"
          v-if="totalPages > 1"
        >

          <li
            class="page-item"
            :class="{disabled: page === 1}"
          >
            <a
              class="page-link"
              :href="getPageUrl(page - 1)"
            >
              Previous
            </a>
          </li>

          <li
            v-for="p in visiblePages"
            :key="p"
            class="page-item"
            :class="{active:p === page}"
          >
            <a
              class="page-link"
              :href="getPageUrl(p)"
            >
              {{ p }}
            </a>
          </li>

          <li
            class="page-item"
            :class="{disabled: page === totalPages}"
          >
            <a
              class="page-link"
              :href="getPageUrl(page + 1)"
            >
              Next
            </a>
          </li>

        </ul>

      </div>

    </div>

  </div>

</div>

<script>

new Vue({

  el:"#app",

  data:{
    search:'<%= search %>',
    page:<%= page %>,
    totalPages:<%= totalPages %>,
    totalMasjids:<%= totalMasjids %>,
    masjids:<%- JSON.stringify(masjids) %>
  },

  computed:{

    visiblePages(){

      let start = Math.max(1, this.page - 2);
      let end = Math.min(this.totalPages, start + 4);

      if(end - start < 4){
        start = Math.max(1, end - 4);
      }

      let pages = [];

      for(let i=start;i<=end;i++){
        pages.push(i);
      }

      return pages;
    }

  },

  methods:{

    searchMasjid(){

      window.location.href =
        `/admin/masjids?page=1&search=${encodeURIComponent(this.search)}`;

    },

    getPageUrl(page){

      return `/admin/masjids?page=${page}&search=${encodeURIComponent(this.search)}`;

    },

    viewMasjid(m){

      alert(
        "Masjid: " + m.masjidName +
        "\nImam: " + m.imamName +
        "\nMobile: " + m.mobile +
        "\nAddress: " + m.address
      );

    },

    async updateStatus(masjid,status){

      try{

        const res = await fetch(
          `/admin/masjids/${masjid._id}/status`,
          {
            method:"POST",
            headers:{
              "Content-Type":"application/json"
            },
            body:JSON.stringify({status})
          }
        );

        if(res.ok){
          masjid.status = status;
        }

      }catch(err){

        alert("Status update failed");

      }

    },

    async deleteMasjid(id){

      if(!confirm("Delete this masjid?")){
        return;
      }

      try{

        const res = await fetch(
          `/admin/masjids/${id}`,
          {
            method:"DELETE"
          }
        );

        if(res.ok){

          this.masjids =
            this.masjids.filter(
              m => m._id !== id
            );

          this.totalMasjids--;

        }

      }catch(err){

        alert("Delete failed");

      }

    }

  }

});

</script>

</body>

</html>

