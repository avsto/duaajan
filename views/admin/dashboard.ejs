<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>DuaAjan Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>

  <style>

    body{
      margin:0;
      background:#0f172a;
      font-family:Arial,sans-serif;
      min-height:100vh;
      color:white;
    }

    .topbar{
      background:#111827;
      padding:20px 30px;
      border-bottom:1px solid rgba(255,255,255,.08);
    }

    .brand{
      font-size:24px;
      font-weight:700;
    }

    .logout-btn{
      background:#ef4444;
      border:none;
      color:white;
      padding:10px 20px;
      border-radius:12px;
      text-decoration:none;
    }

    .dashboard-container{
      padding:40px 20px;
    }

    .card-box{
      background:#111827;
      border-radius:24px;
      padding:30px;
      transition:.3s;
      height:100%;
      border:1px solid rgba(255,255,255,.05);
    }

    .card-box:hover{
      transform:translateY(-5px);
      box-shadow:0 15px 30px rgba(0,0,0,.25);
    }

    .icon-box{
      width:60px;
      height:60px;
      border-radius:18px;
      display:flex;
      align-items:center;
      justify-content:center;
      font-size:24px;
      margin-bottom:20px;
    }

    .users{
      background:rgba(59,130,246,.15);
      color:#60a5fa;
    }

    .live{
      background:rgba(16,185,129,.15);
      color:#34d399;
    }

    .broadcast{
      background:rgba(245,158,11,.15);
      color:#fbbf24;
    }

    .stat-number{
      font-size:38px;
      font-weight:700;
      margin-bottom:5px;
    }

    .stat-title{
      color:#94a3b8;
      font-size:15px;
    }

    .welcome-card{
      background:linear-gradient(135deg,#1e293b,#111827);
      border-radius:24px;
      padding:35px;
      margin-bottom:30px;
    }

  </style>

</head>

<body>

<div id="app">

  <div class="topbar">

    <div class="d-flex justify-content-between align-items-center">

      <div class="brand">
        <i class="fa-solid fa-mosque me-2"></i>
        DuaAjan Dashboard
      </div>

      <a href="/admin/logout" class="logout-btn">
        Logout
      </a>

    </div>

  </div>

  <div class="container dashboard-container">

    <div class="welcome-card">

      <h2>
        Assalamu Alaikum 👋
      </h2>

      <p class="mb-0 text-secondary">
        Welcome to DuaAjan Admin Panel
      </p>

    </div>

    <div class="row">

      <div class="col-md-4 mb-4">
        <a href="/admin/users" class="text-decoration-none text-white">
        <div class="card-box">

          <div class="icon-box users">
            <i class="fa-solid fa-users"></i>
          </div>

          <div class="stat-number">
            {{ stats.users }}
          </div>

          <div class="stat-title">
            Total Users
          </div>

        </div>
        </a>
      </div>

      <div class="col-md-4 mb-4">

        <div class="card-box">

          <div class="icon-box live">
            <i class="fa-solid fa-radio"></i>
          </div>

          <div class="stat-number">
            {{ stats.liveUsers }}
          </div>

          <div class="stat-title">
            Live Users
          </div>

        </div>

      </div>

      <div class="col-md-4 mb-4">
        <a href="/admin/masjids" class="text-decoration-none text-white">
            <div class="card-box">

            <div class="icon-box broadcast">
                <i class="fa-solid fa-tower-broadcast"></i>
            </div>

            <div class="stat-number">
                {{ stats.masjids }}
            </div>

            <div class="stat-title">
                Registered Masjids
            </div>

            </div>
        </a>
      </div>

    </div>

  </div>

</div>

<script>

new Vue({
  el:"#app",

  data:{
    stats:{
      users:<%= stats.users %>,
      liveUsers:<%= stats.liveUsers %>,
      masjids:<%= stats.masjids %>
    }
  }
});

</script>

</body>

</html>

