<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>DuaAjan Admin Dashboard</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>

  <style>

    body{
      margin:0;
      min-height:100vh;
      background:#0f172a;
      font-family:Arial,sans-serif;
      color:white;
    }

    .topbar{
      background:#111827;
      padding:20px 35px;
      border-bottom:1px solid rgba(255,255,255,.08);
      position:sticky;
      top:0;
      z-index:999;
    }

    .brand{
      font-size:24px;
      font-weight:700;
    }

    .logout-btn{
      background:#ef4444;
      color:white;
      padding:10px 18px;
      border-radius:12px;
      text-decoration:none;
      border:none;
    }

    .logout-btn:hover{
      color:white;
      background:#dc2626;
    }

    .dashboard-container{
      padding:35px 20px;
    }

    .welcome-card{
      background:linear-gradient(135deg,#1e293b,#111827);
      border-radius:24px;
      padding:35px;
      margin-bottom:30px;
      border:1px solid rgba(255,255,255,.05);
    }

    .welcome-name{
      color:#60a5fa;
      font-weight:700;
    }

    .card-box{
      background:#111827;
      border-radius:24px;
      padding:30px;
      height:100%;
      transition:.3s;
      border:1px solid rgba(255,255,255,.05);
    }

    .card-box:hover{
      transform:translateY(-6px);
      box-shadow:0 15px 30px rgba(0,0,0,.25);
    }

    .icon-box{
      width:65px;
      height:65px;
      border-radius:18px;
      display:flex;
      justify-content:center;
      align-items:center;
      font-size:24px;
      margin-bottom:20px;
    }

    .users{
      background:rgba(59,130,246,.15);
      color:#60a5fa;
    }

    .live{
      background:rgba(16,185,129,.15);
      color:#34d399;
    }

    .masjid{
      background:rgba(245,158,11,.15);
      color:#fbbf24;
    }

    .ads{
      background:rgba(168,85,247,.15);
      color:#c084fc;
    }

    .stat-number{
      font-size:40px;
      font-weight:700;
      margin-bottom:6px;
    }

    .stat-title{
      color:#94a3b8;
      font-size:15px;
    }

    .menu-card{
      background:#111827;
      border-radius:24px;
      padding:25px;
      margin-top:25px;
      border:1px solid rgba(255,255,255,.05);
    }

    .menu-btn{
      display:block;
      text-decoration:none;
      background:#1e293b;
      color:white;
      padding:18px;
      border-radius:16px;
      margin-bottom:15px;
      transition:.3s;
    }

    .menu-btn:hover{
      background:#334155;
      color:white;
    }

  </style>

</head>

<body>

<div id="app">

  <div class="topbar">

    <div class="d-flex justify-content-between align-items-center">

      <div class="brand">
        <i class="fa-solid fa-mosque me-2"></i>
        DuaAjan Admin
      </div>

      <a href="/admin/logout" class="logout-btn">
        <i class="fa-solid fa-right-from-bracket me-2"></i>
        Logout
      </a>

    </div>

  </div>

  <div class="container dashboard-container">

    <div class="welcome-card">

      <h2>
        Assalamu Alaikum 👋
      </h2>

      <h4 class="welcome-name mt-3">
        <%= admin?.name || admin?.mobile || "Administrator" %>
      </h4>

      <p class="text-secondary mb-0">
        Welcome back to DuaAjan Administration Panel
      </p>

    </div>

    <div class="row">

      <div class="col-lg-3 col-md-6 mb-4">

        <a href="/admin/users" class="text-decoration-none text-white">

          <div class="card-box">

            <div class="icon-box users">
              <i class="fa-solid fa-users"></i>
            </div>

            <div class="stat-number">
              {{ stats.users }}
            </div>

            <div class="stat-title">
              Total Users
            </div>

          </div>

        </a>

      </div>

      <div class="col-lg-3 col-md-6 mb-4">

        <div class="card-box">

          <div class="icon-box live">
            <i class="fa-solid fa-radio"></i>
          </div>

          <div class="stat-number">
            {{ stats.liveUsers }}
          </div>

          <div class="stat-title">
            Live Users
          </div>

        </div>

      </div>

      <div class="col-lg-3 col-md-6 mb-4">

        <a href="/admin/masjids" class="text-decoration-none text-white">

          <div class="card-box">

            <div class="icon-box masjid">
              <i class="fa-solid fa-mosque"></i>
            </div>

            <div class="stat-number">
              {{ stats.masjids }}
            </div>

            <div class="stat-title">
              Registered Masjids
            </div>

          </div>

        </a>

      </div>

      <div class="col-lg-3 col-md-6 mb-4">

        <a href="/admin/ads" class="text-decoration-none text-white">

          <div class="card-box">

            <div class="icon-box ads">
              <i class="fa-solid fa-bullhorn"></i>
            </div>

            <div class="stat-number">
              {{ stats.ads }}
            </div>

            <div class="stat-title">
              Advertisements
            </div>

          </div>

        </a>

      </div>

    </div>

    <div class="menu-card">

      <h4 class="mb-4">
        Quick Navigation
      </h4>

      <a href="/admin/users" class="menu-btn">
        <i class="fa-solid fa-users me-2"></i>
        Manage Users
      </a>

      <a href="/admin/masjids" class="menu-btn">
        <i class="fa-solid fa-mosque me-2"></i>
        Manage Masjids
      </a>

      <a href="/admin/ads" class="menu-btn">
        <i class="fa-solid fa-bullhorn me-2"></i>
        Manage Advertisements
      </a>

    </div>

  </div>

</div>

<script>

new Vue({

  el:"#app",

  data:{

    stats:{
      users:<%= stats.users %>,
      liveUsers:<%= stats.liveUsers %>,
      masjids:<%= stats.masjids %>,
      ads:<%= stats.ads %>
    }

  }

});

</script>

</body>

</html>