<!DOCTYPE html>
<html lang="en">

<head>

    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <title>Create Advertisement - DuaAjan</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

    <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/axios/dist/axios.min.js"></script>

    <style>
        body {
            margin: 0;
            background: #0f172a;
            color: white;
            font-family: Arial, sans-serif;
            min-height: 100vh;
        }

        .topbar {
            background: #111827;
            padding: 20px 30px;
            border-bottom: 1px solid rgba(255, 255, 255, .08);
        }

        .brand {
            font-size: 24px;
            font-weight: 700;
        }

        .page-card {
            background: #111827;
            border-radius: 24px;
            padding: 30px;
            margin-top: 30px;
            border: 1px solid rgba(255, 255, 255, .05);
        }

        .form-control,
        .form-select {
            background: #1e293b;
            border: 1px solid #334155;
            color: white;
            min-height: 52px;
        }

        .form-control:focus,
        .form-select:focus {
            background: #1e293b;
            color: white;
            border-color: #3b82f6;
            box-shadow: none;
        }

        textarea.form-control {
            min-height: 120px;
        }

        .form-control::placeholder {
            color: #94a3b8;
        }

        .preview-card {
            background: #1e293b;
            border-radius: 18px;
            overflow: hidden;
            border: 1px solid rgba(255, 255, 255, .05);
        }

        .preview-image {
            width: 100%;
            height: 220px;
            object-fit: cover;
            background: #0f172a;
        }

        .preview-content {
            padding: 15px;
        }

        .btn-save {
            background: #10b981;
            border: none;
            border-radius: 14px;
            height: 54px;
            padding: 0 30px;
            font-weight: 600;
        }

        .btn-save:hover {
            background: #059669;
        }

        .btn-back {
            background: #334155;
            color: white;
            border: none;
            border-radius: 12px;
        }

        .btn-back:hover {
            background: #475569;
            color: white;
        }

        label {
            margin-bottom: 8px;
            color: #cbd5e1;
        }

        .section-title {
            font-size: 18px;
            font-weight: 700;
            margin-bottom: 20px;
            color: #60a5fa;
        }

        .loading-spinner {
            width: 18px;
            height: 18px;
        }
    </style>

</head>

<body>

    <div id="app">

        <div class="topbar">

            <div class="d-flex justify-content-between align-items-center">

                <div class="brand">
                    <i class="fa-solid fa-bullhorn me-2"></i>
                    Create Advertisement
                </div>

                <a href="/admin/ads" class="btn btn-back">
                    <i class="fa-solid fa-arrow-left me-2"></i>
                    Back
                </a>

            </div>

        </div>

        <div class="container py-4">

            <div class="page-card">

                <div class="row">

                    <!-- FORM -->

                    <div class="col-lg-8">

                        <div class="section-title">
                            Advertisement Information
                        </div>

                        <div class="mb-3">

                            <label>
                                Advertisement Title
                            </label>

                            <input type="text" class="form-control" v-model="form.title"
                                placeholder="Enter advertisement title">

                        </div>

                        <div class="mb-3">

                            <label>
                                Description
                            </label>

                            <textarea class="form-control" v-model="form.description"
                                placeholder="Advertisement description"></textarea>

                        </div>

                        <div class="mb-3">

                            <label>
                                Image URL
                            </label>

                            <input type="text" class="form-control" v-model="form.image"
                                placeholder="https://example.com/banner.jpg">

                        </div>

                        <div class="mb-3">

                            <label>
                                Redirect URL
                            </label>

                            <input type="text" class="form-control" v-model="form.redirectUrl"
                                placeholder="https://example.com">

                        </div>

                        <hr class="border-secondary">

                        <div class="section-title">
                            Advertiser Information
                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label>
                                    Advertiser Name
                                </label>

                                <input type="text" class="form-control" v-model="form.advertiserName">

                            </div>

                            <div class="col-md-6 mb-3">

                                <label>
                                    Advertiser Mobile
                                </label>

                                <input type="text" class="form-control" v-model="form.advertiserMobile">

                            </div>

                        </div>

                        <hr class="border-secondary">

                        <div class="section-title">
                            Advertisement Settings
                        </div>

                        <div class="row">

                            <div class="col-md-4 mb-3">

                                <label>
                                    Ad Type
                                </label>

                                <select class="form-select" v-model="form.adType">

                                    <option value="banner">
                                        Banner
                                    </option>

                                    <option value="slider">
                                        Slider
                                    </option>

                                    <option value="popup">
                                        Popup
                                    </option>

                                    <option value="video">
                                        Video
                                    </option>

                                </select>

                            </div>

                            <div class="col-md-4 mb-3">

                                <label>
                                    Position
                                </label>

                                <select class="form-select" v-model="form.position">

                                    <option value="home_top">
                                        Home Top
                                    </option>

                                    <option value="home_bottom">
                                        Home Bottom
                                    </option>

                                    <option value="live_screen">
                                        Live Screen
                                    </option>

                                    <option value="masjid_screen">
                                        Masjid Screen
                                    </option>

                                    <option value="donation_screen">
                                        Donation Screen
                                    </option>

                                </select>

                            </div>

                            <div class="col-md-4 mb-3">

                                <label>
                                    Status
                                </label>

                                <select class="form-select" v-model="form.isActive">

                                    <option :value="true">
                                        Active
                                    </option>

                                    <option :value="false">
                                        Inactive
                                    </option>

                                </select>

                            </div>

                        </div>

                        <div class="row">

                            <div class="col-md-6 mb-3">

                                <label>
                                    Start Date
                                </label>

                                <input type="date" class="form-control" v-model="form.startDate">

                            </div>

                            <div class="col-md-6 mb-3">

                                <label>
                                    End Date
                                </label>

                                <input type="date" class="form-control" v-model="form.endDate">

                            </div>

                        </div>

                        <button class="btn btn-save text-white mt-3" @click="saveAd" :disabled="loading">

                            <span v-if="loading">

                                <span class="spinner-border spinner-border-sm loading-spinner me-2"></span>

                                Saving...

                            </span>

                            <span v-else>

                                <i class="fa-solid fa-floppy-disk me-2"></i>

                                Save Advertisement

                            </span>

                        </button>

                    </div>

                    <!-- PREVIEW -->

                    <div class="col-lg-4">

                        <div class="section-title">
                            Live Preview
                        </div>

                        <div class="preview-card">

                            <img :src="form.image || 'https://placehold.co/600x300?text=Advertisement+Preview'"
                                class="preview-image">

                            <div class="preview-content">

                                <h5>
                                    {{ form.title || 'Advertisement Title' }}
                                </h5>

                                <p class="text-secondary mb-0">
                                    {{ form.description || 'Advertisement description will appear here.' }}
                                </p>

                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    </div>

    <script>

        new Vue({

            el: "#app",

            data: {

                loading: false,

                form: {

                    title: "",
                    description: "",
                    image: "",
                    redirectUrl: "",

                    advertiserName: "",
                    advertiserMobile: "",

                    adType: "banner",
                    position: "home_top",

                    startDate: "",
                    endDate: "",

                    isActive: true

                }

            },

            methods: {

                async saveAd() {

                    try {

                        if (!this.form.title) {
                            alert("Advertisement title is required");
                            return;
                        }

                        if (!this.form.startDate) {
                            alert("Start date is required");
                            return;
                        }

                        if (!this.form.endDate) {
                            alert("End date is required");
                            return;
                        }

                        this.loading = true;

                        const response = await axios.post(
                            "/admin/ads/create",
                            this.form
                        );

                        alert("Advertisement created successfully");

                        window.location.href = "/admin/ads";

                    } catch (error) {

                        console.log(error);

                        alert(
                            error.response?.data?.message ||
                            "Failed to create advertisement"
                        );

                    } finally {

                        this.loading = false;

                    }

                }

            }

        });

    </script>

</body>

</html>