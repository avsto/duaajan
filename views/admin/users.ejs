<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Users - DuaAjan Admin</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>

  <style>

    body{
      margin:0;
      background:#0f172a;
      color:#fff;
      font-family:Arial,sans-serif;
    }

    .topbar{
      background:#111827;
      padding:20px 30px;
      border-bottom:1px solid rgba(255,255,255,.08);
    }

    .brand{
      font-size:24px;
      font-weight:700;
    }

    .page-card{
      background:#111827;
      border-radius:24px;
      padding:25px;
      margin-top:30px;
      border:1px solid rgba(255,255,255,.05);
    }

    .table{
      color:white;
      margin-bottom:0;
    }

    .table thead{
      background:#1e293b;
    }

    .table th{
      border:none;
      color:#cbd5e1;
      padding:16px;
    }

    .table td{
      border-color:rgba(255,255,255,.05);
      padding:16px;
      vertical-align:middle;
    }

    .search-box{
      background:#1e293b;
      border:none;
      color:white;
      height:50px;
      border-radius:14px;
    }

    .search-box:focus{
      background:#1e293b;
      color:white;
      box-shadow:none;
    }

    .avatar{
      width:42px;
      height:42px;
      border-radius:50%;
      background:#334155;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:bold;
    }

    .badge-live{
      background:#10b981;
    }

    .badge-offline{
      background:#64748b;
    }

    .action-btn{
      border:none;
      border-radius:10px;
      padding:6px 12px;
      margin-right:5px;
    }

    .btn-view{
      background:#3b82f6;
      color:white;
    }

    .btn-delete{
      background:#ef4444;
      color:white;
    }

  </style>

</head>

<body>

<div id="app">

  <!-- Header -->

  <div class="topbar">

    <div class="d-flex justify-content-between align-items-center">

      <div class="brand">
        <i class="fa-solid fa-users me-2"></i>
        Users Management
      </div>

      <a href="/admin/dashboard" class="btn btn-light">
        Dashboard
      </a>

    </div>

  </div>

  <!-- Content -->

  <div class="container py-4">

    <div class="page-card">

      <div class="d-flex justify-content-between align-items-center mb-4">

        <h3 class="mb-0">
          Total Users ({{ filteredUsers.length }})
        </h3>

        <input
          type="text"
          class="form-control search-box"
          style="max-width:300px"
          placeholder="Search user..."
          v-model="search"
        >

      </div>

      <div class="table-responsive">

        <table class="table">

          <thead>

            <tr>
              <th>User</th>
              <th>Mobile</th>
              <th>Location</th>
              <th>Status</th>
              <th>Joined</th>
              <th width="160">Action</th>
            </tr>

          </thead>

          <tbody>

            <tr
              v-for="user in filteredUsers"
              :key="user._id"
            >

              <td>

                <div class="d-flex align-items-center">

                  <div class="avatar me-3">
                    {{ user.name.charAt(0).toUpperCase() }}
                  </div>

                  <div>
                    {{ user.name }}
                  </div>

                </div>

              </td>

              <td>
                {{ user.mobile }}
              </td>

              <td>
                {{ user.location }}
              </td>

              <td>

                <span
                  class="badge"
                  :class="user.isLive ? 'badge-live' : 'badge-offline'"
                >
                  {{ user.isLive ? 'Live' : 'Offline' }}
                </span>

              </td>

              <td>
                {{ formatDate(user.createdAt) }}
              </td>

              <td>

                <button
                  class="action-btn btn-view"
                  @click="viewUser(user)"
                >
                  View
                </button>

                <button
                  class="action-btn btn-delete"
                  @click="deleteUser(user._id)"
                >
                  Delete
                </button>

              </td>

            </tr>

          </tbody>

        </table>

      </div>

    </div>

  </div>

</div>

<script>

new Vue({

  el:"#app",

  data:{
    search:"",

    users: <%- JSON.stringify(users) %>
  },

  computed:{

    filteredUsers(){

      return this.users.filter(user => {

        return (
          user.name?.toLowerCase().includes(this.search.toLowerCase()) ||
          user.mobile?.includes(this.search)
        );

      });

    }

  },

  methods:{

    formatDate(date){

      return new Date(date).toLocaleDateString();

    },

    viewUser(user){

      alert(
        "Name: " + user.name +
        "\nMobile: " + user.mobile
      );

    },

    async deleteUser(id){

      if(!confirm("Delete this user?")) return;

      try{

        await fetch(`/admin/users/${id}`,{
          method:"DELETE"
        });

        this.users =
          this.users.filter(u => u._id !== id);

      }catch(err){

        alert("Delete failed");

      }

    }

  }

});

</script>

</body>

</html>