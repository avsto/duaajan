
<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Users - DuaAjan Admin</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <script src="https://cdn.jsdelivr.net/npm/vue@2/dist/vue.js"></script>

  <style>

    body{
      margin:0;
      background:#0f172a;
      color:#fff;
      font-family:Arial,sans-serif;
    }

    .topbar{
      background:#111827;
      padding:20px 30px;
      border-bottom:1px solid rgba(255,255,255,.08);
    }

    .brand{
      font-size:24px;
      font-weight:700;
    }

    .page-card{
      background:#111827;
      border-radius:24px;
      padding:25px;
      margin-top:30px;
      border:1px solid rgba(255,255,255,.05);
    }

    .table{
      color:white;
      margin-bottom:0;
    }

    .table thead{
      background:#1e293b;
    }

    .table th{
      border:none;
      color:#cbd5e1;
      padding:16px;
    }

    .table td{
      border-color:rgba(255,255,255,.05);
      padding:16px;
      vertical-align:middle;
    }

    .search-box{
      background:#1e293b;
      border:none;
      color:white;
      height:50px;
      border-radius:14px;
    }

    .search-box:focus{
      background:#1e293b;
      color:white;
      box-shadow:none;
    }

    .avatar{
      width:42px;
      height:42px;
      border-radius:50%;
      background:#334155;
      display:flex;
      align-items:center;
      justify-content:center;
      font-weight:bold;
    }

    .badge-live{
      background:#10b981;
    }

    .badge-offline{
      background:#64748b;
    }

    .action-btn{
      border:none;
      border-radius:10px;
      padding:6px 12px;
      margin-right:5px;
    }

    .btn-view{
      background:#3b82f6;
      color:white;
    }

    .btn-delete{
      background:#ef4444;
      color:white;
    }

    .pagination .page-link{
      background:#1e293b;
      border-color:#334155;
      color:#fff;
    }

    .pagination .active .page-link{
      background:#3b82f6;
      border-color:#3b82f6;
    }

    .pagination .disabled .page-link{
      background:#111827;
      color:#64748b;
    }

  </style>

</head>

<body>

<div id="app">

  <div class="topbar">

    <div class="d-flex justify-content-between align-items-center">

      <div class="brand">
        <i class="fa-solid fa-users me-2"></i>
        Users Management
      </div>

      <a href="/admin/dashboard" class="btn btn-light">
        Dashboard
      </a>

    </div>

  </div>

  <div class="container py-4">

    <div class="page-card">

      <div class="d-flex justify-content-between align-items-center mb-4">

        <h3 class="mb-0">
          Total Users ({{ totalUsers }})
        </h3>

        <input
          type="text"
          class="form-control search-box"
          style="max-width:300px"
          placeholder="Search user..."
          v-model="search"
          @keyup.enter="searchUsers"
        >

      </div>

      <div class="table-responsive">

        <table class="table">

          <thead>

            <tr>
              <th>User</th>
              <th>Mobile</th>
              <th>Location</th>
              <th>Status</th>
              <th>Joined</th>
              <th width="160">Action</th>
            </tr>

          </thead>

          <tbody>

            <tr
              v-for="user in users"
              :key="user._id"
            >

              <td>

                <div class="d-flex align-items-center">

                  <div class="avatar me-3">
                    {{ user.name ? user.name.charAt(0).toUpperCase() : 'U' }}
                  </div>

                  <div>
                    {{ user.name }}
                  </div>

                </div>

              </td>

              <td>{{ user.mobile }}</td>

              <td>{{ user.location }}</td>

              <td>

                <span
                  class="badge"
                  :class="user.isLive ? 'badge-live' : 'badge-offline'"
                >
                  {{ user.isLive ? 'Live' : 'Offline' }}
                </span>

              </td>

              <td>
                {{ formatDate(user.createdAt) }}
              </td>

              <td>

                <button
                  class="action-btn btn-view"
                  @click="viewUser(user)"
                >
                  View
                </button>

                <button
                  class="action-btn btn-delete"
                  @click="deleteUser(user._id)"
                >
                  Delete
                </button>

              </td>

            </tr>

            <tr v-if="users.length === 0">

              <td colspan="6" class="text-center py-4">
                No Users Found
              </td>

            </tr>

          </tbody>

        </table>

      </div>

      <div class="d-flex justify-content-between align-items-center mt-4">

        <div>
          Page {{ page }} of {{ totalPages }}
        </div>

        <nav v-if="totalPages > 1">

          <ul class="pagination mb-0">

            <li
              class="page-item"
              :class="{ disabled: page === 1 }"
            >
              <a
                class="page-link"
                :href="getPageUrl(page - 1)"
              >
                Previous
              </a>
            </li>

            <li
              v-for="p in visiblePages"
              :key="p"
              class="page-item"
              :class="{ active: p === page }"
            >
              <a
                class="page-link"
                :href="getPageUrl(p)"
              >
                {{ p }}
              </a>
            </li>

            <li
              class="page-item"
              :class="{ disabled: page === totalPages }"
            >
              <a
                class="page-link"
                :href="getPageUrl(page + 1)"
              >
                Next
              </a>
            </li>

          </ul>

        </nav>

      </div>

    </div>

  </div>

</div>

<script>

new Vue({

  el:"#app",

  data:{
    search:'<%= search %>',
    page:<%= page %>,
    totalPages:<%= totalPages %>,
    totalUsers:<%= totalUsers %>,
    users:<%- JSON.stringify(users) %>
  },

  computed:{

    visiblePages(){

      let start = Math.max(1, this.page - 2);
      let end = Math.min(this.totalPages, start + 4);

      if(end - start < 4){
        start = Math.max(1, end - 4);
      }

      let pages = [];

      for(let i = start; i <= end; i++){
        pages.push(i);
      }

      return pages;
    }

  },

  methods:{

    formatDate(date){

      return new Date(date)
        .toLocaleDateString();

    },

    searchUsers(){

      window.location.href =
        `/admin/users?page=1&search=${encodeURIComponent(this.search)}`;

    },

    getPageUrl(page){

      return `/admin/users?page=${page}&search=${encodeURIComponent(this.search)}`;

    },

    viewUser(user){

      alert(
        "Name: " + user.name +
        "\nMobile: " + user.mobile +
        "\nLocation: " + user.location
      );

    },

    async deleteUser(id){

      if(!confirm("Delete this user?")){
        return;
      }

      try{

        const response = await fetch(
          `/admin/users/${id}`,
          {
            method:"DELETE"
          }
        );

        if(response.ok){

          this.users =
            this.users.filter(
              u => u._id !== id
            );

          this.totalUsers--;

        }

      }catch(error){

        alert("Delete failed");

      }

    }

  }

});

</script>

</body>

</html>

