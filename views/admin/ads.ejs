<!DOCTYPE html>
<html lang="en">

<head>

  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  <title>Ads Management</title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">

  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.2/css/all.min.css">

  <style>

    body{
      background:#0f172a;
      color:#fff;
      font-family:Arial,sans-serif;
    }

    .topbar{
      background:#111827;
      padding:20px 30px;
      border-bottom:1px solid rgba(255,255,255,.08);
    }

    .page-card{
      background:#111827;
      border-radius:20px;
      padding:25px;
      margin-top:25px;
    }

    .table{
      color:white;
    }

    .table thead{
      background:#1e293b;
    }

    .table td,
    .table th{
      border-color:rgba(255,255,255,.08);
      vertical-align:middle;
    }

    .ad-image{
      width:80px;
      height:50px;
      object-fit:cover;
      border-radius:8px;
    }

    .badge-active{
      background:#10b981;
    }

    .badge-inactive{
      background:#ef4444;
    }

  </style>

</head>

<body>

<div class="topbar">

  <div class="d-flex justify-content-between align-items-center">

    <h3 class="mb-0">
      <i class="fa-solid fa-bullhorn me-2"></i>
      Ads Management
    </h3>

    <div>

      <a href="/admin/ads/create" class="btn btn-success">
        Add Ad
      </a>

      <a href="/admin/dashboard" class="btn btn-light">
        Dashboard
      </a>

    </div>

  </div>

</div>

<div class="container">

  <div class="page-card">

    <div class="table-responsive">

      <table class="table">

        <thead>

          <tr>
            <th>Image</th>
            <th>Title</th>
            <th>Position</th>
            <th>Advertiser</th>
            <th>Clicks</th>
            <th>Views</th>
            <th>Status</th>
            <th>Action</th>
          </tr>

        </thead>

        <tbody>

          <% ads.forEach(ad => { %>

            <tr>

              <td>

                <% if(ad.image){ %>

                  <img
                    src="<%= ad.image %>"
                    class="ad-image"
                  >

                <% } else { %>

                  -

                <% } %>

              </td>

              <td>
                <%= ad.title %>
              </td>

              <td>
                <%= ad.position %>
              </td>

              <td>
                <%= ad.advertiserName || "-" %>
              </td>

              <td>
                <%= ad.clicks %>
              </td>

              <td>
                <%= ad.impressions %>
              </td>

              <td>

                <% if(ad.isActive){ %>

                  <span class="badge badge-active">
                    Active
                  </span>

                <% } else { %>

                  <span class="badge badge-inactive">
                    Inactive
                  </span>

                <% } %>

              </td>

              <td>

                <a
                  href="/admin/ads/edit/<%= ad._id %>"
                  class="btn btn-sm btn-primary"
                >
                  Edit
                </a>

                <button
                  class="btn btn-sm btn-danger"
                  onclick="deleteAd('<%= ad._id %>')"
                >
                  Delete
                </button>

              </td>

            </tr>

          <% }) %>

        </tbody>

      </table>

    </div>

  </div>

</div>

<script>

async function deleteAd(id){

  if(!confirm("Delete this ad?")){
    return;
  }

  try{

    const res = await fetch(
      `/admin/ads/${id}`,
      {
        method:"DELETE"
      }
    );

    if(res.ok){
      location.reload();
    }

  }catch(err){

    alert("Delete failed");

  }

}

</script>

</body>

</html>